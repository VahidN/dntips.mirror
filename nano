!/bin/bash

SITE_DIR="/usr/share/nginx/html/wwwroot/App_Data/exports/EpubDocs"

cd "$SITE_DIR" || exit

# اگر تغییری وجود ندارد، کاری نکن
if git diff --quiet && git diff --cached --quiet; then
    exit 0
fi

git add -A

# جلوگیری از commit خالی
if git diff --cached --quiet; then
    exit 0
fi

git commit -m "auto update $(date +'%F %T')"
git push origin main
